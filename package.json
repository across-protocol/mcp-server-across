{
  "name": "mcp-server-across",
  "version": "1.0.0",
  "description": "MCP server that indexes Across Protocol documentation for AI-powered cross-chain development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-across": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "crawl": "node dist/crawler.js --standalone"
  },
  "keywords": [
    "mcp",
    "across-protocol",
    "cross-chain",
    "bridge",
    "documentation",
    "ai",
    "claude",
    "cursor"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "htmlparser2": "^9.1.0",
    "domutils": "^3.1.0",
    "dom-serializer": "^2.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
